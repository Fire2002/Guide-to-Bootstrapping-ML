# fast-bootstrapping, Python example

import numpy as np

# --- Step 1: Create sample dataset ---
np.random.seed(42)
data = np.random.normal(loc=50, scale=10, size=1000)

# --- Step 2: Fast bootstrap (vectorized) ---
n_bootstrap = 10000
n_samples = len(data)

# Generate all bootstrap indices at once
indices = np.random.randint(0, n_samples, size=(n_bootstrap, n_samples))

# Resample data using advanced indexing
bootstrap_samples = data[indices]

# Compute statistic (mean) across each bootstrap sample
bootstrap_means = bootstrap_samples.mean(axis=1)

# --- Step 3: Results ---
mean_estimate = bootstrap_means.mean()
confidence_interval = np.percentile(bootstrap_means, [2.5, 97.5])

print(f"Bootstrap Mean Estimate: {mean_estimate:.2f}")
print(f"95% Confidence Interval: {confidence_interval}")
