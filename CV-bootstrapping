# CV-bootstrapping, Python example

import numpy as np

np.random.seed(42)

X = np.random.randn(100, 3)
true_coef = np.array([2, -1, 0.5])
y = X @ true_coef + np.random.normal(0, 1, size=100)

# bootstrap evaluation with OOB error
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error

n_boot = 200
n = len(X)

model = LinearRegression()
oob_errors = []

for _ in range(n_boot):
    # Bootstrap sample indices
    train_idx = np.random.choice(n, size=n, replace=True)
    
    # Out-of-bag indices (not selected)
    oob_mask = np.ones(n, dtype=bool)
    oob_mask[train_idx] = False
    test_idx = np.where(oob_mask)[0]
    
    # Skip if no OOB samples (rare but possible)
    if len(test_idx) == 0:
        continue
    
    X_train, y_train = X[train_idx], y[train_idx]
    X_test, y_test = X[test_idx], y[test_idx]
    
    model.fit(X_train, y_train)
    y_pred = model.predict(X_test)
    
    mse = mean_squared_error(y_test, y_pred)
    oob_errors.append(mse)

print("Average OOB MSE:", np.mean(oob_errors))
